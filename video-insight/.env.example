# 复制此文件为 .env 并填入真实值（.env 已被 .gitignore 排除，不会提交）
# 或者通过 ~/.openclaw/openclaw.json 的 skills.entries.env 字段配置（推荐）

# 推荐新手：只需填这一个，即可访问多模型
OPENROUTER_API_KEY=sk-or-xxx

# 国内单 key 选项（任选其一即可开始使用）
DEEPSEEK_API_KEY=sk-xxx        # DeepSeek，性价比标杆
VOLCENGINE_API_KEY=xxx         # 豆包/火山引擎（字节）
DASHSCOPE_API_KEY=sk-xxx       # 通义千问（阿里）
MINIMAX_API_KEY=xxx            # MiniMax，1M超大上下文
ZHIPU_API_KEY=xxx              # 智谱GLM，Flash版免费
MOONSHOT_API_KEY=sk-xxx        # Kimi，长文本强

# 国际模型
OPENAI_API_KEY=sk-xxx          # OpenAI GPT系列
